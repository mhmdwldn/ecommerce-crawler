# ============================================================================
# Tokopedia Crawler — environment variable template
# ----------------------------------------------------------------------------
# Copy to .env and fill in values. NEVER commit the real .env file.
# Nested settings use a double underscore: TOKOPEDIA_<SECTION>__<FIELD>
# Env vars override config.yaml; config.yaml overrides built-in defaults.
# ============================================================================

# --- Global ---
TOKOPEDIA_ENVIRONMENT=development
TOKOPEDIA_LOG_LEVEL=INFO

# --- Kafka ---
TOKOPEDIA_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
TOKOPEDIA_KAFKA__TOPIC=tokopedia.products.raw
TOKOPEDIA_KAFKA__CLIENT_ID=tokopedia-crawler

# --- Elasticsearch ---
TOKOPEDIA_ELASTICSEARCH__HOSTS=["http://localhost:9200"]
TOKOPEDIA_ELASTICSEARCH__INDEX_NAME=tokopedia_products
# TOKOPEDIA_ELASTICSEARCH__API_KEY=
# TOKOPEDIA_ELASTICSEARCH__USERNAME=
# TOKOPEDIA_ELASTICSEARCH__PASSWORD=

# --- Crawler (HTTP / GraphQL) ---
TOKOPEDIA_CRAWLER__BASE_URL=https://gql.tokopedia.com
TOKOPEDIA_CRAWLER__SITE_URL=https://www.tokopedia.com
TOKOPEDIA_CRAWLER__X_VERSION=a3540b9
TOKOPEDIA_CRAWLER__USER_DISTRICT_ID=2274
TOKOPEDIA_CRAWLER__USER_CITY_ID=176
TOKOPEDIA_CRAWLER__DEFAULT_ROWS=20
TOKOPEDIA_CRAWLER__RATE_LIMIT_RPS=5.0
# Session-bound secrets — set only when needed, never commit:
# TOKOPEDIA_CRAWLER__COOKIES=
# TOKOPEDIA_CRAWLER__DEVICE_ID=
# TOKOPEDIA_CRAWLER__PROXY_URL=

# --- Shopee (separate SHOPEE_ namespace) ---
SHOPEE_BASE_URL=https://shopee.co.id
SHOPEE_DEFAULT_LIMIT=60
SHOPEE_RATE_LIMIT_RPS=2.0
# search_items is anti-bot gated: supply a real browser session.
# Cookies + rotating tokens are SECRETS — never commit a filled-in .env.
# SHOPEE_COOKIES="SPC_F=...; csrftoken=...; SPC_ST=...; SPC_U=..."
# SHOPEE_EXTRA_HEADERS='{"x-sap-sec":"...","x-sap-ri":"...","sz-token":"...","af-ac-enc-dat":"..."}'
# SHOPEE_PROXY_URL=http://user:pass@residential-proxy:8080
